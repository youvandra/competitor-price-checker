# Apify — https://console.apify.com/account/integrations
APIFY_TOKEN=
APIFY_AMAZON_ACTOR=axesso_data~amazon-product-offers-scraper

# x402 / X Layer
X402_MODE=off                 # off | demo | on
X402_PAY_TO=                  # your X Layer wallet (receives USDT0)
X402_PRICE_USD=0.4            # price per paid call

# OKX facilitator creds (required when X402_MODE=on)
XLAYER_API_KEY=
XLAYER_SECRET_KEY=
XLAYER_PASSPHRASE=

# tuning
OFFERS_CACHE_TTL_MS=600000    # cache Amazon offers 10 min (cuts Apify cost + latency)
UNDERCUT_STEP=0.01            # how much to undercut the Buy Box by
PORT=3002
NODE_ENV=development
APIFY_EBAY_ACTOR=automation-lab~ebay-scraper
EBAY_MAX_ITEMS=20
APIFY_WALMART_ACTOR=pear_fight~walmart-scraper
WALMART_MAX_ITEMS=20
APIFY_ALIEXPRESS_ACTOR=kawsar~aliexpress-search-scraper
ALIEXPRESS_MAX_ITEMS=20
APIFY_ETSY_ACTOR=automation-lab~etsy-scraper
ETSY_MAX_ITEMS=20
APIFY_TARGET_ACTOR=ecomscrape~target-product-search-scraper
TARGET_MAX_ITEMS=20
APIFY_BESTBUY_ACTOR=gio21~bestbuy-scraper
BESTBUY_MAX_ITEMS=20
APIFY_MERCADOLIBRE_ACTOR=scrapers_lat~mercadolibre-scraper
MERCADOLIBRE_MAX_ITEMS=20
MERCADOLIBRE_COUNTRY=br       # ar | mx | br | co | cl
APIFY_SHOPEE_ACTOR=gio21~shopee-scraper
SHOPEE_MAX_ITEMS=20
SHOPEE_COUNTRY=ID             # BR | SG | MY | TH | ID | MX | PH | VN
X402_COMPARE_PRICE_USD=1.5   # Best Price Scan (cross-marketplace)
